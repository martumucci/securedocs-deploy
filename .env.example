# Images. By default the stack pulls the published images from GHCR
# (public packages, no login required) — no source checkout needed.
# Pin to an immutable tag for reproducible runs, e.g.:
#   ghcr.io/martumucci/securedocs-api:sha-36b4254
API_IMAGE=ghcr.io/martumucci/securedocs-api:latest
WORKER_IMAGE=ghcr.io/martumucci/securedocs-crypto-worker:latest

# Build from local source instead of pulling: point these at the sibling
# repos and run `docker compose up --build`. Defaults assume they are cloned
# next to this repo with their canonical names.
API_PATH=../securedocs-api
WORKER_PATH=../securedocs-crypto-worker
