# Paths to the sibling source repos, used when building images locally.
# Defaults assume they are cloned next to this repo with their canonical names.
# Override only if your layout differs.
API_PATH=../securedocs-api
WORKER_PATH=../securedocs-crypto-worker

# Image names. Local builds tag with these. Once CI publishes to a registry,
# point these at the registry (e.g. ghcr.io/<owner>/securedocs-api:<tag>) and
# run `docker compose up` (without --build) to pull instead of build.
API_IMAGE=securedocs-api:local
WORKER_IMAGE=securedocs-crypto-worker:local
